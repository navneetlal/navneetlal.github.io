---
export interface Props {
  href?: string;
  class?: string;
}

const { href, class: extra = '' } = Astro.props;
const Tag = href ? 'a' : 'span';
---

<Tag
  href={href}
  class:list={[
    'inline-flex items-center rounded-full bg-accent-indigo-bg px-[10px] py-[3px] font-mono text-[10px] text-accent-indigo',
    href && 'transition-colors hover:bg-accent-indigo hover:text-paper',
    extra,
  ]}
>
  <slot />
</Tag>
