---
import Pill from '../ui/Pill.astro';
import { tagSlug } from '../../lib/tags.ts';

export interface Props {
  category: string;
  title: string;
  description?: string;
  publishedAt: Date;
  updatedAt?: Date;
  readingMinutes: number;
  backHref?: string;
  backLabel?: string;
}

const {
  category,
  title,
  description,
  publishedAt,
  updatedAt,
  readingMinutes,
  backHref = '/writing/',
  backLabel = '/writing',
} = Astro.props;

const pubStr = publishedAt.toISOString().slice(0, 10);
const updStr = updatedAt?.toISOString().slice(0, 10);
const shareLinks = [
  { href: `https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.toString())}`, label: '𝕏', aria: 'Share on X' },
  { href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.toString())}`, label: 'in', aria: 'Share on LinkedIn' },
  { href: Astro.url.toString(), label: '⧉', aria: 'Copy link' },
];
---

<header class="mx-auto max-w-[760px]">
  <a
    href={backHref}
    class="inline-flex items-center gap-1 font-mono text-xs text-ink-500 hover:text-ink-900"
  >
    ← {backLabel}
  </a>

  <div class="mt-10">
    <Pill tone="indigo">
      <span class="font-mono uppercase tracking-[0.18em]">{category}</span>
    </Pill>
  </div>

  <h1 class="mt-8 text-3xl font-bold leading-[1.1] tracking-tight text-ink-900 md:text-[44px]">
    {title}
  </h1>

  {
    description && (
      <p class="mt-6 text-base italic text-ink-500 md:text-lg">{description}</p>
    )
  }

  <div class="mt-10 flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <span
        class="grid size-10 place-items-center rounded-full bg-ink-100 font-mono text-sm font-bold text-ink-700"
        aria-hidden="true"
      >
        NL
      </span>
      <div>
        <p class="text-sm font-bold text-ink-900">Navneet Lal Gupta</p>
        <p class="font-mono text-[11px] text-ink-500">
          {pubStr} · {readingMinutes} min read
          {updStr && ` · Updated ${updStr}`}
        </p>
      </div>
    </div>

    <ul class="flex items-center gap-2">
      {
        shareLinks.map((s) => (
          <li>
            <a
              href={s.href}
              aria-label={s.aria}
              target="_blank"
              rel="noopener"
              class="grid size-8 place-items-center rounded-md bg-paper-softer text-ink-700 hover:bg-ink-100 hover:text-ink-900"
            >
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>
