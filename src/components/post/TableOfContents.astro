---
import type { MarkdownHeading } from 'astro';

export interface Props {
  headings: MarkdownHeading[];
  /** Only include headings with depth in this range. */
  minDepth?: number;
  maxDepth?: number;
}

const { headings, minDepth = 2, maxDepth = 3 } = Astro.props;
const items = headings.filter(
  (h) => h.depth >= minDepth && h.depth <= maxDepth,
);
---

{
  items.length > 0 && (
    <nav aria-label="Table of contents" class="text-sm">
      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-500">
        // ON THIS PAGE
      </p>
      <ol class="mt-4 flex flex-col gap-2">
        {items.map((h) => (
          <li class:list={[h.depth === 3 && 'pl-3']}>
            <a
              href={`#${h.slug}`}
              class="block leading-snug text-ink-500 transition-colors hover:text-ink-900"
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
