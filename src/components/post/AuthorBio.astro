---
import EyebrowLabel from '../ui/EyebrowLabel.astro';
---

<aside class="rounded-xl border border-ink-100 bg-paper-soft p-6 md:p-8">
  <EyebrowLabel label="AUTHOR" tone="muted" />
  <div class="mt-5 flex items-start gap-4">
    <span
      class="grid size-14 shrink-0 place-items-center rounded-full bg-ink-100 font-mono text-base font-bold text-ink-700"
      aria-hidden="true"
    >
      NL
    </span>
    <div class="flex-1">
      <p class="text-base font-bold text-ink-900">Navneet Lal Gupta</p>
      <p class="mt-1 text-sm text-ink-700">
        Backend tech lead in Bangalore — 7+ years building distributed
        backend systems and leading platform-wide migrations across
        runtimes, container platforms, and CI/CD. Currently building
        real-time data infra at a multi-tenant SaaS platform.
      </p>
      <ul class="mt-3 flex flex-wrap gap-4 text-sm font-semibold text-ink-900">
        <li>
          <a class="hover:underline" href="/work/">Work</a>
        </li>
        <li>
          <a class="hover:underline" href="/about/">About</a>
        </li>
        <li>
          <a class="hover:underline" href="mailto:navneetlalg@gmail.com">
            Get in touch
          </a>
        </li>
      </ul>
    </div>
  </div>
</aside>
