---
export interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;

const links = [
  {
    href: `https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`,
    label: 'Share on X',
  },
  {
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
    label: 'Share on LinkedIn',
  },
  {
    href: `https://news.ycombinator.com/submitlink?u=${encodeURIComponent(url)}&t=${encodeURIComponent(title)}`,
    label: 'Share on HN',
  },
];
---

<aside class="rounded-xl border border-ink-100 bg-paper p-5 text-sm">
  <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-500">
    // SHARE
  </p>
  <ul class="mt-3 flex flex-col gap-2">
    {
      links.map((l) => (
        <li>
          <a
            href={l.href}
            target="_blank"
            rel="noopener"
            class="text-ink-700 hover:text-ink-900"
          >
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>
</aside>
