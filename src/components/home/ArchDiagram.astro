---
export interface Props {
  /** Show the wrapping bordered card. */
  framed?: boolean;
  class?: string;
}

const { framed = true, class: extra = '' } = Astro.props;
---

<div
  class:list={[
    'h-full w-full',
    framed && 'rounded-2xl border border-ink-300 bg-paper-softer p-5',
    extra,
  ]}
>
  <p class="font-mono text-[10px] text-ink-500">// signature_arch.diagram</p>

  <svg
    viewBox="0 0 360 280"
    xmlns="http://www.w3.org/2000/svg"
    class="mt-4 h-auto w-full max-w-md"
    role="img"
    aria-label="Architecture diagram: Mongo CDC into Kafka into StarRocks, with a Spark + Iceberg branch feeding ML/analytics."
  >
    <defs>
      <marker
        id="arr"
        viewBox="0 0 10 10"
        refX="8"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto"
      >
        <path d="M0,0 L10,5 L0,10 z" fill="currentColor"></path>
      </marker>
    </defs>

    <g class="text-ink-900">
      <rect
        x="10"
        y="40"
        width="90"
        height="40"
        rx="6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"></rect>
      <text x="22" y="65" font-size="11" fill="currentColor" font-family="ui-monospace, monospace">
        Mongo CDC
      </text>

      <line x1="100" y1="60" x2="135" y2="60" stroke="currentColor" stroke-width="1.5" marker-end="url(#arr)"></line>

      <rect x="135" y="40" width="80" height="40" rx="6" fill="currentColor"></rect>
      <text x="156" y="65" font-size="11" fill="#fafaf9" font-family="ui-monospace, monospace">
        Kafka
      </text>

      <line x1="215" y1="60" x2="250" y2="60" stroke="currentColor" stroke-width="1.5" marker-end="url(#arr)"></line>

      <rect
        x="250"
        y="40"
        width="90"
        height="40"
        rx="6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"></rect>
      <text x="262" y="65" font-size="11" fill="currentColor" font-family="ui-monospace, monospace">
        StarRocks
      </text>

      <line x1="175" y1="80" x2="175" y2="125" stroke="currentColor" stroke-width="1.5" marker-end="url(#arr)"></line>

      <rect
        x="115"
        y="125"
        width="130"
        height="40"
        rx="6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"></rect>
      <text
        x="132"
        y="150"
        font-size="11"
        fill="currentColor"
        font-family="ui-monospace, monospace"
      >
        Spark + Iceberg
      </text>

      <line
        x1="180"
        y1="165"
        x2="180"
        y2="200"
        stroke="#94a3b8"
        stroke-width="1"
        stroke-dasharray="4 3"></line>
      <rect
        x="115"
        y="200"
        width="130"
        height="40"
        rx="6"
        fill="#f1f5f9"
        stroke="#94a3b8"
        stroke-dasharray="4 3"></rect>
      <text
        x="135"
        y="225"
        font-size="11"
        fill="#475569"
        font-family="ui-monospace, monospace"
      >
        ML / Analytics
      </text>
    </g>
  </svg>

  <p class="mt-4 font-mono text-[10px] text-ink-500">
    // real-time + historical, one platform
  </p>
</div>
