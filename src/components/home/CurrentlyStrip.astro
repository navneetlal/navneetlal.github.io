---
import Container from '../layout/Container.astro';
import EyebrowLabel from '../ui/EyebrowLabel.astro';
---

<section class="border-y border-ink-100 bg-paper-soft">
  <Container class="py-14 md:py-16">
    <EyebrowLabel label="CURRENTLY" />
    <p class="mt-6 max-w-[60ch] text-xl leading-snug text-ink-900 md:text-2xl">
      Tech Lead at a <strong class="font-bold">multi-tenant SaaS platform</strong>,
      based in Bangalore — building real-time data infra and leading
      platform-wide migrations across runtimes and CI/CD.
    </p>
  </Container>
</section>
