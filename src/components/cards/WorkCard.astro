---
import type { CollectionEntry } from 'astro:content';
import Tag from '../ui/Tag.astro';

export interface Props {
  entry: CollectionEntry<'work'>;
  caseNumber?: number;
}

const { entry, caseNumber } = Astro.props;
const { data, id } = entry;
const href = `/work/${id}/`;

const eyebrow =
  data.coverEyebrow ??
  (caseNumber !== undefined
    ? `// case ${String(caseNumber).padStart(2, '0')}`
    : '// case');
---

<article
  class="flex h-full flex-col overflow-hidden rounded-xl border border-ink-100 bg-paper-soft transition-shadow hover:shadow-md"
>
  <a href={href} class="block">
    <div
      class="flex h-[180px] flex-col justify-between p-5 text-paper"
      style={`background-color: ${data.coverColor};`}
    >
      <span class="font-mono text-[10px] text-paper/70">{eyebrow}</span>
      <div>
        <h3 class="text-[22px] font-bold leading-tight">{data.title}</h3>
        <p class="mt-2 font-mono text-[11px] text-paper/75">{data.blurb}</p>
      </div>
    </div>
  </a>

  <div class="flex flex-1 flex-col p-5">
    <p class="text-[11px] text-ink-500">
      {data.company} · {data.period} · {data.role}
    </p>

    {
      data.metrics.length > 0 && (
        <ul class="mt-3 flex flex-col gap-1 text-[14px] font-semibold text-ink-900">
          {data.metrics.slice(0, 3).map((m) => (
            <li class="flex items-baseline gap-2">
              <span class="font-mono text-[11px] uppercase tracking-wide text-ink-500">
                {m.label}
              </span>
              <span>{m.value}</span>
            </li>
          ))}
        </ul>
      )
    }

    {
      data.stack.length > 0 && (
        <ul class="mt-auto flex flex-wrap gap-2 pt-5">
          {data.stack.slice(0, 4).map((s) => (
            <li>
              <Tag>{s}</Tag>
            </li>
          ))}
        </ul>
      )
    }

    <a
      href={href}
      class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-ink-900 hover:text-ink-700"
    >
      Read case study <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
