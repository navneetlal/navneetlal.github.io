---
import type { CollectionEntry } from 'astro:content';
import Tag from '../ui/Tag.astro';

export interface Props {
  entry: CollectionEntry<'writing'>;
  variant?: 'plain' | 'covered';
}

const { entry, variant = 'plain' } = Astro.props;
const { data, id } = entry;
const href = `/writing/${id}/`;

const dateStr = data.publishedAt.toISOString().slice(0, 10);
const categoryLabel = data.category.toUpperCase();
---

<article
  class="flex h-full flex-col overflow-hidden rounded-xl border border-ink-100 bg-paper transition-shadow hover:shadow-md"
>
  {
    variant === 'covered' && (
      <a href={href} class="block">
        <div
          class="flex h-[170px] flex-col justify-between p-5 text-paper"
          style={`background-color: ${data.coverColor ?? '#0f172a'};`}
        >
          {data.coverEyebrow && (
            <span class="font-mono text-[10px] text-paper/70">{data.coverEyebrow}</span>
          )}
          <div>
            {data.coverTitle && (
              <p class="text-base font-bold leading-tight">{data.coverTitle}</p>
            )}
            {data.coverSubtitle && (
              <p class="mt-1 font-mono text-[11px] text-paper/70">{data.coverSubtitle}</p>
            )}
          </div>
        </div>
      </a>
    )
  }

  <div class="flex flex-1 flex-col p-5">
    <p class="font-mono text-[11px] text-ink-500">
      {dateStr} · {data.readingMinutes} min · {categoryLabel}
    </p>

    <h3 class="mt-3 text-[19px] font-bold leading-tight text-ink-900">
      <a href={href} class="hover:text-ink-700">{data.title}</a>
    </h3>

    {
      data.description && (
        <p class="mt-3 line-clamp-3 text-sm text-ink-700">{data.description}</p>
      )
    }

    {
      data.tags.length > 0 && (
        <ul class="mt-auto flex flex-wrap gap-2 pt-5">
          {data.tags.slice(0, 3).map((t) => (
            <li>
              <Tag href={`/writing/tag/${t.toLowerCase()}/`}>{t}</Tag>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>
