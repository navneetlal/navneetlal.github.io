---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import EyebrowLabel from '../../components/ui/EyebrowLabel.astro';
import WorkCard from '../../components/cards/WorkCard.astro';

const entries = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Work — Navneet Lal Gupta"
  description="Case studies: real-time analytics, EC2→EKS migration, GPS telemetry, runtime upgrades, activity ingestion."
>
  <Container class="py-16 md:py-20">
    <EyebrowLabel label="WORK" />
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-ink-900 md:text-5xl">
      Things I've built and led
    </h1>
    <p class="mt-6 max-w-3xl text-base text-ink-700">
      Selected case studies — platform migrations, distributed backends,
      data infra, and the occasional runtime-upgrade death march. Anonymized;
      numbers are from the résumé.
    </p>

    <ul class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        entries.map((entry, idx) => (
          <li>
            <WorkCard entry={entry} caseNumber={idx + 1} />
          </li>
        ))
      }
    </ul>
  </Container>
</BaseLayout>
