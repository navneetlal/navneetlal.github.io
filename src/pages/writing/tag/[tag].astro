---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/layout/Container.astro';
import EyebrowLabel from '../../../components/ui/EyebrowLabel.astro';
import PostCard from '../../../components/cards/PostCard.astro';
import { collectTagSlugs, postsMatchingSlug } from '../../../lib/tags.ts';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  const slugs = collectTagSlugs(posts);
  return slugs.map(({ slug, label, count }) => ({
    params: { tag: slug },
    props: { slug, label, count, posts },
  }));
}

const { slug, label, posts } = Astro.props;
const matches = postsMatchingSlug(posts, slug).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title={`${label} — Writing — Navneet Lal Gupta`}
  description={`Posts tagged ${label}.`}
>
  <Container class="py-16 md:py-20">
    <a
      href="/writing/"
      class="inline-flex items-center gap-1 font-mono text-xs text-ink-500 hover:text-ink-900"
    >
      ← /writing
    </a>

    <EyebrowLabel label="WRITING" class="mt-8" />
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-ink-900 md:text-5xl">
      {label}
    </h1>
    <p class="mt-6 text-base text-ink-700">
      {matches.length} post{matches.length === 1 ? '' : 's'} on {label.toLowerCase()}.
    </p>

    <ul class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        matches.map((entry) => (
          <li>
            <PostCard entry={entry} variant="covered" />
          </li>
        ))
      }
    </ul>
  </Container>
</BaseLayout>
